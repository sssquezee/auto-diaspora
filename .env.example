# Auto Diaspora — environment variables (template)
# Copy to .env.local and fill in real values. .env.local is gitignored.
# Source of truth: PROJECT_SPEC.md section 8.

# ===== Supabase (Day 1) =====
# Get from: Supabase Dashboard → Project → Settings → Data API / API Keys
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
# secret — server-only, never exposed to browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# ===== Site =====
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Auto Diaspora"

# ===== Mollie (Day 5) =====
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxx

# ===== Google OAuth (self-hosted flow) =====
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID.
# The Authorized redirect URI registered there must match GOOGLE_REDIRECT_URI.
# No Supabase dashboard provider config is required — the flow runs in our
# own /api/auth/google routes and mints the session via service-role.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional — defaults to ${NEXT_PUBLIC_SITE_URL}/api/auth/google/callback
GOOGLE_REDIRECT_URI=https://autodiaspora.com/api/auth/google/callback

# ===== Admin panel =====
# Comma-separated list of profile UUIDs allowed into /admin.
# Find your id: Supabase Dashboard → Authentication → Users → click your row.
ADMIN_USER_IDS=

# ===== Telegram bot (Day 6) =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=AutoDiasporaBot
# Public — used by the Telegram Login Widget on the auth pages (client).
# Same value as TELEGRAM_BOT_USERNAME, but must be NEXT_PUBLIC_ to reach
# the browser. Login-with-Telegram button is hidden when empty.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=AutoDiasporaBot
# Personal chat id with the bot — owner gets pending-listing pings here.
# Find it: send /start to your bot, then call
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# and look at chat.id in the response.
TELEGRAM_ADMIN_CHAT_ID=

# ===== Email — Resend (Day 7) =====
RESEND_API_KEY=
EMAIL_FROM=noreply@autodiaspora.com

# ===== Cron protection (Day 6-7) =====
# Generate via: openssl rand -hex 32
CRON_SECRET=

# ===== Error monitoring =====
# Get from: sentry.io → Settings → Projects → Client Keys (DSN)
# Sentry is no-op when this is empty.
NEXT_PUBLIC_SENTRY_DSN=
